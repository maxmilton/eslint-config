{
  "name": "@maxmilton/eslint-config",
  "version": "0.3.3",
  "description": "ESLint configuration with support for Bun, TypeScript, and more",
  "bugs": "https://github.com/maxmilton/eslint-config/issues",
  "repository": "github:maxmilton/eslint-config",
  "license": "MIT",
  "author": "Max Milton <max@2okki.com>",
  "type": "module",
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "files": [
    "src"
  ],
  "scripts": {
    "lint": "bun lint:fmt && bun lint:js && bun lint:ts",
    "lint:fmt": "biome check",
    "lint:js": "eslint",
    "lint:ts": "tsc --noEmit",
    "test": "bun test --only-failures",
    "test:ci": "bun test --coverage --randomize --rerun-each=3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@eslint/js": "10.0.1",
    "@types/bun": "1.3.14",
    "eslint": "10.6.0",
    "eslint-plugin-unicorn": "70.0.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1"
  },
  "peerDependencies": {
    "@eslint/js": "^10.0.0",
    "eslint": "^10.0.0",
    "eslint-plugin-unicorn": ">=70.0.0",
    "typescript-eslint": "^8.62.1"
  },
  "peerDependenciesMeta": {
    "eslint-plugin-unicorn": {
      "optional": true
    }
  }
}
